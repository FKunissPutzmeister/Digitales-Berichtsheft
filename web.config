<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="Node.js Reverse Proxy" stopProcessing="true">
          <match url="(.*)" />
          <!-- Node läuft mit NODE_ENV=production und secure Session-Cookies.
               Express erkennt die HTTPS-Terminierung von IIS nur an diesem
               Header (trust proxy) - ohne ihn wird das Cookie nie gesetzt.
               EINMALIG auf dem Server freischalten, sonst wirft IIS 500:
               appcmd set config -section:system.webServer/rewrite/allowedServerVariables /+"[name='HTTP_X_FORWARDED_PROTO']" /commit:apphost -->
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          </serverVariables>
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
